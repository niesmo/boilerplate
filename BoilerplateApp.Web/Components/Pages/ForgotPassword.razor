@page "/forgot-password"
@rendermode InteractiveServer
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Forgot Password</PageTitle>

<h1>Reset your password</h1>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="model" OnValidSubmit="HandleForgotPasswordAsync" FormName="forgot-password">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="model.Email" />
                <ValidationMessage For="@(() => model.Email)" />
            </div>

            <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
                @(isSubmitting ? "Preparing reset..." : "Generate reset link")
            </button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(infoMessage))
        {
            <div class="alert alert-info mt-3" role="alert">
                @infoMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(resetLink))
        {
            <div class="alert alert-warning mt-3" role="alert">
                <p class="mb-2">Development mode: use this reset link.</p>
                <a href="@resetLink">@resetLink</a>
            </div>
        }
    </div>
</div>

@code {
    private readonly ForgotPasswordInput model = new();
    private bool isSubmitting;
    private string? infoMessage;
    private string? resetLink;

    private async Task HandleForgotPasswordAsync()
    {
        isSubmitting = true;
        infoMessage = null;
        resetLink = null;

        var user = await UserManager.FindByEmailAsync(model.Email);
        if (user is null)
        {
            infoMessage = "If an account exists for that email, a reset link is available.";
            isSubmitting = false;
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var encodedToken = Microsoft.AspNetCore.WebUtilities.WebEncoders.Base64UrlEncode(
            System.Text.Encoding.UTF8.GetBytes(token));
        var encodedEmail = Uri.EscapeDataString(user.Email ?? string.Empty);
        resetLink = NavigationManager.BaseUri.TrimEnd('/') +
            $"/reset-password?email={encodedEmail}&token={encodedToken}";

        infoMessage = "Password reset link generated.";
        isSubmitting = false;
    }

    private sealed class ForgotPasswordInput
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}